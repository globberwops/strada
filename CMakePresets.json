{
  "version": 5,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Config",
      "description": "Standard single-configuration build using Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "dev",
      "displayName": "Development Config",
      "description": "Multi-configuration build with ccache and Ninja Multi-Config",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo"
      }
    },
    {
      "name": "san",
      "displayName": "Sanitizers Config",
      "description": "Multi-configuration build with Address and Undefined Behavior Sanitizers",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/san",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "cov",
      "displayName": "Coverage Config",
      "description": "Multi-configuration build with code coverage instrumentation",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/cov",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "--coverage",
        "CMAKE_C_FLAGS": "--coverage",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage",
        "CMAKE_SHARED_LINKER_FLAGS": "--coverage"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default-debug",
      "configurePreset": "default",
      "configuration": "Debug"
    },
    {
      "name": "default-release",
      "configurePreset": "default",
      "configuration": "Release"
    },
    {
      "name": "dev-debug",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "dev-release",
      "configurePreset": "dev",
      "configuration": "Release"
    },
    {
      "name": "san-debug",
      "configurePreset": "san",
      "configuration": "Debug"
    },
    {
      "name": "cov-debug",
      "configurePreset": "cov",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "default-debug",
      "configurePreset": "default",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "default-release",
      "configurePreset": "default",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-debug",
      "configurePreset": "dev",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-release",
      "configurePreset": "dev",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "san-debug",
      "configurePreset": "san",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cov-debug",
      "configurePreset": "cov",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
